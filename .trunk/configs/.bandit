[bandit]
# .bandit
# Directories to include in the scan
targets: .
# Directories or files to skip
exclude: tests,venv,.venv,__pycache__,migrations

# Severity levels: LOW, MEDIUM, HIGH
severity-level: MEDIUM

# Confidence levels: LOW, MEDIUM, HIGH
confidence-level: MEDIUM

# Output format: json, txt, xml, csv, yaml
format: json

# Number of worker processes
number: 4

# Show skipped tests in output
show-skipped: True

# Tests to skip (comma-separated test IDs)
# B008 - Do not perform function call `Body` in argument defaults;
#        instead, perform the call within the function,
#        or read the default from a module-level singleton variable
# B101 - assert statements (required by pytest)
# B104 - binding to all interfaces (intentional for remote serves)
# B311 - pseudo-random generators (used for non-security purposes
#        e.g. pagination shuffle)
# B404 - Possible security implications associated with the subprocess module
# B603 - subprocess call with untrusted input (inputs are validated upstream)
# B604 - Function call with shell=True parameter identified, possible security issue
# B607 - Starting a process with a partial executable path
# B608 - Probable insecure usage of temp file/directory
# B615 - incomplete URL schemes
skips = B008,B101,B104,B108,B311,B404,B603,B604,B607,B608,B615